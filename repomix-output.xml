      auth.login(
        {
          id: user.id,
          username: user.username,
          email: user.email,
          first_name: "",
          last_name: "",
          profile: {
            role: user.role as any,
            phone: user.phone || null,
            address: null,
          },
          donor_profile: user.role === "DONOR" && user.donorProfile
            ? {
                total_donations: 0,
                reliability_score: 100,
