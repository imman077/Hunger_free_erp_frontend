                    <ResuableInput
                      label="Tier Name"
                      value={editableTierName}
                      onChange={setEditableTierName}
                      placeholder="e.g. Bronze, Gold"
                    />
                    <ResuableInput
                      label="Point Range"
                      value={editableTierRange}
                      onChange={setEditableTierRange}
                      placeholder="e.g. 500 - 1000"
