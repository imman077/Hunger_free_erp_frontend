                           <div className="flex gap-2">
                             <input 
                               type="text" 
                               maxLength={4}
                               className="flex-1 bg-white/5 border border-[var(--border-color)] rounded-lg text-center font-black tracking-widest text-sm h-9 outline-none focus:border-[#22c55e]/50 transition-all"
