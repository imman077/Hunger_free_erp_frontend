    >
      <Table
        isCompact
        isHeaderSticky
        aria-label="Master Audit Ledger"
        bottomContent={bottomContent}
        bottomContentPlacement="outside"
        classNames={{
          base: "border-collapse bg-transparent",
          table: "bg-transparent",
