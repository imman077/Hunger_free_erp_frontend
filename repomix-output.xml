  }, [
    page,
    pages,
    enablePagination,
    rowsPerPage,
    onRowsPerPageChange,
    onNextPage,
    onPreviousPage,
  ]);

  return (
    <div
      className="border rounded-sm flex flex-col relative gap-4 w-full"
      style={{
