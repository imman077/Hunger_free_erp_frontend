                className="w-full rounded-2xl h-14 text-[11px] font-black uppercase tracking-[0.2em] bg-[var(--bg-secondary)] text-[var(--text-secondary)] hover:bg-[var(--bg-hover)] transition-all order-2"
                onPress={onSuspenseClose}
              >
                Cancel Action
              </Button>
            </ModalFooter>
          </ModalContent>
        </Modal>
      </div>
    </div>
  );
};

