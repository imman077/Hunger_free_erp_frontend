}

export interface ActionConfig<T = any> {
  showView?: boolean;
  showMessage?: boolean;
  showApprove?: boolean;
  showDeactivate?: boolean;
  showDelete?: boolean;
  onView?: (item: T) => void;
  onMessage?: (item: T) => void;
  onApprove?: (item: T) => void;
  onDeactivate?: (item: T) => void;
