            "bg-transparent",
            "text-[10px]",
            "font-bold",
            "uppercase",
            "tracking-[0.15em]",
            "text-[var(--text-muted)]",
            "whitespace-nowrap",
            variant === "compact" ? "py-2.5 px-3" : "py-4 px-5",
