    const validatedOutput = createDonationApiOutputSchema.parse(response);

    createDonationApiOutputModel.update({
      loading: false,
      data: validatedOutput.data,
    });

    return validatedOutput;
  } catch (err) {
    createDonationApiOutputModel.update({ loading: false });
    throw err;
  }
}
