    url: string;
    name: string;
  } | null>(null);

  const CATEGORIES_CONFIG: Record<
    string,
    { label: string; icon: any; fields: string[] }
  > = {
    contact: {
      label: "Contact Info",
      icon: <User size={16} />,
      fields: ["Full Name", "Primary Email", "Phone Number", "Base Location"],
    },
    transport: {
      label: "Transport",
      icon: <Bike size={16} />,
      fields: ["Vehicle Type", "Model Name", "License Plate", "Insurance Info"],
    },
    legal: {
