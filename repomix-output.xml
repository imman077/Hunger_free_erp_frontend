                  page === i + 1
                    ? "bg-hf-green text-white scale-105 shadow-sm"
                    : "border"
                }`}
                style={{
                  backgroundColor:
                    page === i + 1 ? "#22c55e" : "var(--bg-primary)",
                  borderColor: "var(--border-color)",
                  color: page === i + 1 ? "white" : "var(--text-primary)",
