                    "0 0 0 8px rgba(34, 197, 94, 0.1)",
                    "0 0 0 0px rgba(34, 197, 94, 0)",
                  ],
                }}
                exit={{ opacity: 0, scale: 0.5 }}
                transition={{
                  scale: { repeat: Infinity, duration: 2, ease: "easeInOut" },
